# --- WEB APP (Frontend) ---
# Where the Web App is hosted and accessed from
WEB_HOST=192.168.1.50
WEB_PORT=50001
# Internal port for the Next.js container (default: 3000)
WEB_INTERNAL_PORT=3000

# --- API (Backend) ---
# Where the API is hosted (Public IP/Domain)
API_HOST=192.168.1.50
API_PORT=50002
# Internal port for the Rust container (default: 50002)
API_INTERNAL_PORT=50002

# --- DATABASE ---
# Hostname or IP of the Database.
# Use 'db' if running within the same Docker network.
# Use an IP (e.g., 192.168.1.55) if the DB is on a different server.
DB_HOST=db
DB_PORT=5432

# --- CREDENTIALS ---
POSTGRES_USER=user_kanban
POSTGRES_PASSWORD=password_safe
POSTGRES_DB=kanban_db

# --- SECRETS ---
JWT_SECRET=super_secret_jwt_key_change_me
